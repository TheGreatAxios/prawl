# Apple Developer Credentials for Code Signing
# 
# INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Fill in your actual values in .env
# 3. .env is gitignored by default - NEVER commit it!
#
# Alternative: Use macOS Keychain (see AGENTS.md)

# Your Apple Developer Team ID (10 characters)
# Get it from: https://developer.apple.com/account (Membership details)
APPLE_TEAM_ID=XXXXXXXXXX

# Your Apple ID email address
APPLE_ID=your.email@example.com

# App-specific password for notarization
# Generate at: https://appleid.apple.com (Security → App-Specific Passwords)
APPLE_APP_PASSWORD=abcd-efgh-ijkl-mnop
